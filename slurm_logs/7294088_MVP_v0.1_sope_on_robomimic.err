# Rerun oracle rollouts with per-step reward scoring (LiftRewardFn)
# This ensures oracle V^Ď€ uses the same reward signal as OPE scoring:
# sum of per-step rewards (1.0 for each step where cube_z > 0.84)
from latent_sope.eval.oracle import oracle_value, save_oracle_result
from latent_sope.eval.reward_model import LiftRewardFn, make_lift_encoder

ckpt = load_checkpoint(str(CKPT_DIR))
reward_fn = LiftRewardFn()
encoder = make_lift_encoder()

print(f"Running 50 oracle rollouts with per-step reward scoring...")
print(f"Reward fn: {reward_fn}")

oracle_result = oracle_value(
    ckpt,
    num_rollouts=50,
    horizon=60,
    gamma=GAMMA,
    device=str(device),
    verbose=True,
    num_workers=0,
    reward_fn=reward_fn,
    encoder=encoder,
)

oracle_returns = oracle_result.returns
oracle_value_v = oracle_result.mean_return

print(f"\nOracle V^Ď€ (per-step reward) = {oracle_value_v:.4f} Â± {oracle_result.std_return:.4f}")
print(f"Per-rollout returns: min={oracle_returns.min():.1f}, max={oracle_returns.max():.1f}")

# Save updated oracle results
save_oracle_result(ORACLE_JSON, oracle_result, policy_name="diffusion_policy")
print(f"Saved updated oracle to {ORACLE_JSON}")
