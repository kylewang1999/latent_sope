# ── Run oracle evaluation for all 12 policies ──
# Uses _rollout_with_reward_fn which records per-step obs (including final next_obs
# on success termination — avoids the known Bug #1 in rollout.py).

results = {}
t0_all = time.time()

for i, pol in enumerate(TARGET_POLICIES):
    name = pol["name"]
    run_dir = CKPT_BASE / pol["dir"]
    ckpt_path = pol["ckpt"]

    print(f"\n[{i+1}/{len(TARGET_POLICIES)}] {name}")
    print(f"  Checkpoint: {run_dir / ckpt_path}")

    t0 = time.time()
    ckpt = load_checkpoint(run_dir, ckpt_path=Path(ckpt_path))
    result = oracle_value(
        ckpt,
        num_rollouts=NUM_ROLLOUTS,
        horizon=HORIZON,
        gamma=GAMMA,
        device=DEVICE,
        verbose=True,
        num_workers=0,       # required for reward_fn path
        reward_fn=reward_fn,
        encoder=encoder,
    )
    elapsed = time.time() - t0

    results[name] = {
        "mean_return": result.mean_return,
        "std_return": result.std_return,
        "per_rollout_returns": result.returns.tolist(),
        "gamma": GAMMA,
        "horizon": HORIZON,
        "num_rollouts": NUM_ROLLOUTS,
    }

    print(f"  mean={result.mean_return:.3f} +/- {result.std_return:.3f}  "
          f"(min={result.returns.min():.1f}, max={result.returns.max():.1f})  "
          f"[{elapsed:.0f}s]")

total_time = time.time() - t0_all
print(f"\nTotal time: {total_time:.0f}s ({total_time/60:.1f} min)")
